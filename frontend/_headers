/*
 * Cloudflare Pages - Headers de seguridad y caching
 * https://developers.cloudflare.com/pages/platform/headers/
 */

 /*
# Security Headers
X-Frame-Options: DENY
X-Content-Type-Options: nosniff
Referrer-Policy: strict-origin-when-cross-origin
Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://*.clerk.com https://*.supabase.co wss://*.supabase.co; font-src 'self' data:;

# Caching Headers
# Static assets: cache por 1 año
/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML: no cache
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# API: no cache
/api/*
  Cache-Control: no-cache
 */
